{
  "manifest_version": 3,
  "name": "Horizon Tab",
  "version": "1.9.0",
  "description": "A minimal, beautiful, customizable new tab page — your horizon, your way.",
  "chrome_url_overrides": {
    "newtab": "tab.html"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://*.google.com/search*",
    "*://duckduckgo.com/*",
    "*://search.brave.com/search*",
    "*://safebrowsing.googleapis.com/*"
  ],
  "background": {
    "service_worker": "aiscan/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/search*",
        "*://duckduckgo.com/*",
        "*://search.brave.com/search*",
    "*://safebrowsing.googleapis.com/*"
      ],
      "js": ["aiscan/score.js", "aiscan/content.js"],
      "css": ["aiscan/badge.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://*.google.com/search*",
        "*://duckduckgo.com/*",
        "*://search.brave.com/search*",
    "*://safebrowsing.googleapis.com/*"
      ],
      "js": ["aiscan/score.js", "aiscan/detector.js"],
      "css": ["aiscan/badge.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "horizon-tab@rishvanthamsaraj"
    }
  }
}
